# Git 与本地产物
.git
.gitignore
**/__pycache__
**/*.pyc
**/*.log
logs/
*.db
outputs/
test_outputs/
*.concat_list.txt
test_list.txt

# 依赖与构建缓存（镜像内重新安装/构建）
frontend/node_modules
frontend/dist
backend/.venv
venv
.venv

# 密钥（运行时由 compose env_file 注入）
.env
backend/.env
frontend/.env*

# 文档、参考项目、测试（减小镜像上下文）
projects/
skills/
test/
terminals/
agent-transcripts/
*.md
!README.md
auto_enter.py
run_e2e_test.bat
test_e2e.bat
scripts/
