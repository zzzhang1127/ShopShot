# 环境变量（仅根目录 .env，含 API Key，勿提交）
.env
backend/.env
frontend/.env
frontend/.env.*

# 参考仓库体积大，不纳入主仓库；仅追踪 projects/README.md，请用户自行 clone
projects/*
!projects/README.md

# 本地自动化（个人环境）
auto_enter.py

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/

# 日志（任意目录，运行时产生，勿提交）
*.log
logs/
err.log
out.log
backend.log
backend_start.log
backend/e2e_server*.log
backend/out.txt
backend/out2.txt
backend/thread_test_out.txt
backend/server_out.log
backend/uvicorn*.log

# 数据库
*.db
backend/shopshot.db

# 模板目录（运行时生成，体积可增长）
data/templates/catalog.json
data/templates/catalog.json.tmp
data/templates/video_gen_meta.json
data/templates/expand_meta.json
data/templates/expand_meta.json

# AI 生成与上传产物
outputs/
outputs/**

# API 联调结果（历史误提交，勿再追踪）
outputs/api_results/

# FFmpeg / 测试临时文本（非源码；requirements.txt 等仍提交）
*.concat_list.txt
**/concat_list.txt
test_list.txt
backend/test_scripts*.json
test_outputs/

# 媒体二进制（outputs 等；评测集 datasets/eval 需提交）
*.mp4
*.jpg
*.jpeg
*.png
!datasets/eval/
!datasets/eval/**

# 前端构建与工具缓存
frontend/dist/
frontend/node_modules/
frontend/node_modules/.tmp/
**/.tmp/
**/*.tsbuildinfo

# IDE / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
