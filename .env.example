# ShopShot 环境变量（复制到项目根目录 .env 并填入真实值）
# 后端与前端共用此文件；勿在 backend/ 或 frontend/ 下再建 .env

# --- 火山方舟 API ---
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLC_API_KEY=your-api-key-here
DOUBAO_SEED_EP=your-seed-endpoint-id
DOUBAO_SEEDANCE_EP=your-seedance-endpoint-id

# --- 应用 / 数据库 / 存储 ---
APP_NAME=ShopShot
DEBUG=true
DATABASE_URL=sqlite:///./shopshot.db
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=../outputs

# --- 功能开关（必须为 false 才走真实 API）---
MOCK_MODE=false
IMAGE_GENERATION_ENABLED=false

# --- Seedance 限流（深度模式会连续提交多镜，建议保持默认）---
SEEDANCE_CONCURRENCY=1
SEEDANCE_MIN_SUBMIT_INTERVAL=15
SEEDANCE_MAX_RETRY=6
SEEDANCE_RATE_LIMIT_WAIT_SECONDS=45
SEEDANCE_POLL_INTERVAL=10

# --- Docker（可选）---
# SHOPSHOT_PORT=8000

# --- 前端（可选；开发默认走 Vite 代理；Docker 单容器同源无需填）---
# VITE_API_BASE=http://127.0.0.1:8000/api/v1
