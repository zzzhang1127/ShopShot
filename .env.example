# ShopShot 环境变量（复制到项目根目录 .env 并填入真实值）
# 后端与前端共用此文件；勿在 backend/ 或 frontend/ 下再建 .env

# --- 火山方舟 API ---
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLC_API_KEY=your-api-key-here
DOUBAO_SEED_EP=your-seed-endpoint-id
DOUBAO_SEEDANCE_EP=your-seedance-endpoint-id

# --- 应用 / 数据库 / 存储 ---
APP_NAME=ShopShot
DEBUG=true
DATABASE_URL=sqlite:///./shopshot.db
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=../outputs

# --- 功能开关（必须为 false 才走真实 API）---
MOCK_MODE=false
IMAGE_GENERATION_ENABLED=false
TTS_GENERATION_ENABLED=false

# --- 阿里百炼 / Wan（Wan-skills + Wan2.2，可选）---
# DASHSCOPE_API_KEY=your-dashscope-key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/
WAN_PROMPT_ENHANCE_ENABLED=true
WAN_IMAGE_ENABLED=false
WAN_IMAGE_MODEL=wan2.7-image
WAN_VIDEO_ENABLED=false
WAN_VIDEO_MODEL=wan2.1-i2v-plus
WAN_AUTO_REFERENCE_IMAGES=true

# --- ComfyUI（可选，不配置不影响主链路）---
COMFYUI_ENABLED=false
# COMFYUI_URL=http://127.0.0.1:8188
# COMFYUI_API_KEY=
COMFYUI_POLL_INTERVAL=1.5
COMFYUI_TIMEOUT_SECONDS=300

# --- Seedance 限流（深度模式会连续提交多镜，建议保持默认）---
SEEDANCE_CONCURRENCY=1
SEEDANCE_MIN_SUBMIT_INTERVAL=15
SEEDANCE_MAX_RETRY=6
SEEDANCE_RATE_LIMIT_WAIT_SECONDS=45
SEEDANCE_POLL_INTERVAL=10

# --- 带货模板目录（首页 100+ 模板 + 后台 Seed 扩充）---
TEMPLATE_CATALOG_PATH=data/templates/catalog.json
TEMPLATE_CATALOG_MIN_COUNT=100
TEMPLATE_EXPAND_ENABLED=true
TEMPLATE_EXPAND_TARGET=200
TEMPLATE_EXPAND_INTERVAL_SECONDS=120
TEMPLATE_EXPAND_BATCH_SIZE=5

# --- 模板视频生成（后台调用 Seedance 为每个模板生成独立预览）---
TEMPLATE_VIDEO_GEN_ENABLED=true
TEMPLATE_VIDEO_GEN_INTERVAL_SECONDS=30

# --- Docker（可选）---
# SHOPSHOT_PORT=8000

# --- 前端（可选；开发默认走 Vite 代理；Docker 单容器同源无需填）---
# VITE_API_BASE=http://127.0.0.1:8000/api/v1
